<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <LinearLayout
        android:id="@+id/message_bubble_content"
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bubble_sent_blue"
        android:paddingStart="10dp"
        android:paddingTop="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/message_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:maxWidth="280dp"
            android:text="Message"
            tools:text="This is a message I sent."/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="end"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tv_timestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="4dp"
                tools:text="10:15 AM"
                tools:visibility="gone"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/iv_read_receipt"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/ic_check_double"
                android:contentDescription="Read receipt"
                android:visibility="gone"
                android:layout_gravity="center_vertical"
                app:civ_border_color="@android:color/white"
                app:civ_border_width="0.5dp"
                tools:visibility="visible"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>